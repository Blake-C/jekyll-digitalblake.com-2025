{
	"tabWidth": 4,
	"useTabs": true,
	"printWidth": 120,
	"singleQuote": true,
	"semi": false,
	"arrowParens": "avoid",
	"plugins": ["@shopify/prettier-plugin-liquid"],
	"overrides": [
		{
			"files": ["*.html", "*.liquid"],
			"options": {
				"parser": "liquid-html",
				"singleQuote": false
			}
		}
	]
}
